{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Voice",
  "version": "0.1.0",
  "identifier": "com.openclaw.voice.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:8765/voice",
    "frontendDist": "http://127.0.0.1:8765/voice"
  },
  "app": {
    "security": {
      "pattern": {
        "use": "brownfield"
      }
    },
    "windows": [],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
